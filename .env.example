# Neon Postgres (tables live in schema `hdws_public`, not `public`)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=hdwallpapers
R2_PUBLIC_URL=https://static.hdwallpapers.site

# Better Auth — production: use your canonical host (www)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Production example:
# BETTER_AUTH_URL=https://www.hdwallpapers.site

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email
RESEND_API_KEY=
EMAIL_FROM=noreply@hdwallpapers.site
CONTACT_EMAIL=legal@hdwallpapers.site

# App (must match BETTER_AUTH_URL in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production example:
# NEXT_PUBLIC_SITE_URL=https://www.hdwallpapers.site
NEXT_PUBLIC_CDN_URL=https://static.hdwallpapers.site
# NEXT_PUBLIC_USE_MEDIA_PROXY=true
REQUIRE_MODERATION=true
CRON_SECRET=
DOWNLOAD_SECRET=

# Mobile app support (see docs/mobile-api.md)
# Extra trusted origins for better-auth (custom schemes / dev hosts), comma-separated
MOBILE_APP_ORIGINS=
# Browser/WebView origins allowed to call /api with credentials, comma-separated.
# If empty, /api uses permissive CORS (Access-Control-Allow-Origin: *, no credentials).
API_CORS_ORIGINS=

# Admin seed password (bcrypt hash, used by seed script)
ADMIN_PASSWORD=changeme

# Sam Johnson creator seed password (bcrypt hash, used by pnpm seed:sam)
CREATOR_PASSWORD=SamJohnson2026!

# Cloudflare Turnstile (production only — disabled automatically in local dev)
# Get free keys at: https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
